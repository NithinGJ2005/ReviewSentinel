+def login(username: str, password: str) -> bool:
+    db = sqlite3.connect("users.db")
+    cursor = db.execute(
+        "SELECT id FROM users WHERE user=? AND pass=?",
+        (username, password)
+    )
+    row = cursor.fetchone()
+    db.close()
+    return row is not None
